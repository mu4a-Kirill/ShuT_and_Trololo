<Page x:Class="ShuT_and_Trololo.Pages.StranitsaAdmina"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E">

    <Page.Resources>
        <Style TargetType="Button" x:Key="BtnFiolet">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6D28D9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="BtnZelen">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#047857"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="BtnKrasn">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="BtnSer">
            <Setter Property="Background" Value="#3D3D5F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4D4D6F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="#A78BFA"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#7C3AED"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Администрирование"
                   FontSize="24" FontWeight="Bold"
                   Foreground="#C4B5FD" Margin="0,0,0,16"/>

        <TabControl Grid.Row="1"
                    Background="#1E1E2E"
                    BorderBrush="#3D3D5F">

            <TabItem Header="⚠ Жалобы">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="panelZhaloby" Margin="12"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="❄ Разморозка">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="panelRazmorozka" Margin="12"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="📝 Заявки на автора">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="panelZayavki" Margin="12"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="🔒 Заморожено">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="Замороженные книги"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#93C5FD" Margin="0,0,0,10"/>
                        <StackPanel x:Name="panelZamKnigi" Margin="0,0,0,20"/>

                        <Separator Background="#3D3D5F" Margin="0,0,0,16"/>

                        <TextBlock Text="Замороженные пользователи"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#93C5FD" Margin="0,0,0,10"/>
                        <StackPanel x:Name="panelZamPolz" Margin="0,0,0,20"/>

                        <Separator Background="#3D3D5F" Margin="0,0,0,16"/>

                        <TextBlock Text="Замороженные отзывы"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#93C5FD" Margin="0,0,0,10"/>
                        <StackPanel x:Name="panelZamOtzyvy"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="👥 Пользователи">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="panelPolzovateli" Margin="12"/>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Page>