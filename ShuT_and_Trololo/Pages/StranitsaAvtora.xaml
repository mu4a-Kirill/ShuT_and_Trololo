<Page x:Class="ShuT_and_Trololo.Pages.StranitsaAvtora"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E">

    <Page.Resources>
        <Style TargetType="Button" x:Key="BtnFiolet">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6D28D9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="BtnSer">
            <Setter Property="Background" Value="#3D3D5F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4D4D6F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="BtnZelen">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#047857"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Страница автора"
                   FontSize="24" FontWeight="Bold"
                   Foreground="#C4B5FD" Margin="0,0,0,16"/>

        <Button Grid.Row="1" Content="+ Добавить новую книгу"
                Style="{StaticResource BtnFiolet}"
                HorizontalAlignment="Left"
                Margin="0,0,0,20"
                Click="btnDobavit_Click"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="panelKnigiAvtora"/>
        </ScrollViewer>

        <Separator Grid.Row="3" Background="#3D3D5F" Margin="0,16"/>

        <StackPanel Grid.Row="4">
            <TextBlock Text="❄ Замороженные книги"
                       FontSize="17" FontWeight="SemiBold"
                       Foreground="#93C5FD" Margin="0,0,0,12"/>
            <StackPanel x:Name="panelZamorozhen"/>
        </StackPanel>
    </Grid>
</Page>