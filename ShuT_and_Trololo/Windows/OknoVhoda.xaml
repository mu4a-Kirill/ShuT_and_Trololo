<Window x:Class="ShuT_and_Trololo.Windows.OknoVhoda"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай, Пиши и не спиши" Height="500" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Window.Resources>
        <Style TargetType="Button" x:Key="BtnObich">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6D28D9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox" x:Key="PolVvoda">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#7C3AED"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <Style TargetType="PasswordBox" x:Key="PolParol">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#7C3AED"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="50,0">

            <TextBlock Text="📚 Читай, Пиши" FontSize="22" FontWeight="Bold"
                       Foreground="#C4B5FD" HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>
            <TextBlock Text="и не спиши®" FontSize="14"
                       Foreground="#8B5CF6" HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnVhod" Content="Вход" Grid.Column="0"
                        Style="{StaticResource BtnObich}"
                        Click="btnVhod_Click"/>
                <Button x:Name="btnReg" Content="Регистрация" Grid.Column="1"
                        Background="#3D3D5F" Foreground="White"
                        FontSize="14" Padding="10,8" BorderThickness="0"
                        Cursor="Hand" Click="btnReg_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#3D3D5F"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4D4D6F"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <StackPanel x:Name="panelVhod">
                <TextBlock Text="Логин" Foreground="#C4B5FD" Margin="0,0,0,4"/>
                <TextBox x:Name="txtLogin" Style="{StaticResource PolVvoda}"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Пароль" Foreground="#C4B5FD" Margin="0,0,0,4"/>
                <PasswordBox x:Name="pbParol" Style="{StaticResource PolParol}"
                             Margin="0,0,0,20"/>

                <Button Content="Войти" Style="{StaticResource BtnObich}"
                        Click="BtnVoyti_Click"/>
            </StackPanel>

            <StackPanel x:Name="panelReg" Visibility="Collapsed">
                <TextBlock Text="Логин" Foreground="#C4B5FD" Margin="0,0,0,4"/>
                <TextBox x:Name="txtRegLogin" Style="{StaticResource PolVvoda}"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Имя / Отображаемое имя" Foreground="#C4B5FD"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="txtRegImya" Style="{StaticResource PolVvoda}"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Email" Foreground="#C4B5FD" Margin="0,0,0,4"/>
                <TextBox x:Name="txtRegEmail" Style="{StaticResource PolVvoda}"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Пароль (мин. 4 символа)" Foreground="#C4B5FD"
                           Margin="0,0,0,4"/>
                <PasswordBox x:Name="pbRegParol" Style="{StaticResource PolParol}"
                             Margin="0,0,0,20"/>

                <Button Content="Зарегистрироваться"
                        Style="{StaticResource BtnObich}"
                        Click="BtnZaregistrirovat_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>