<Window x:Class="ShuT_and_Trololo.Windows.OknoRedaktirovaniyaKnigi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книга" Height="680" Width="580"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button" x:Key="BtnFiolet">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6D28D9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="BtnSer">
            <Setter Property="Background" Value="#3D3D5F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4D4D6F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox" x:Key="PolVvoda">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#7C3AED"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <TextBlock x:Name="txtZagolovok" Text="Добавить книгу"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#C4B5FD" Margin="0,0,0,20"/>

            <!-- Название -->
            <TextBlock Text="Название *" Foreground="#C4B5FD" Margin="0,0,0,4"/>
            <TextBox x:Name="txtTitle" Style="{StaticResource PolVvoda}"
                     Margin="0,0,0,14"/>

            <!-- Описание -->
            <TextBlock Text="Описание" Foreground="#C4B5FD" Margin="0,0,0,4"/>
            <TextBox x:Name="txtDesc" Style="{StaticResource PolVvoda}"
                     Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                     Margin="0,0,0,14"/>

            <!-- Обложка -->
            <TextBlock Text="Обложка" Foreground="#C4B5FD" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtCoverPath"
                         Style="{StaticResource PolVvoda}"
                         IsReadOnly="True" Grid.Column="0"
                         Text="Файл не выбран"/>
                <Button Grid.Column="2" Content="Выбрать..."
                        Style="{StaticResource BtnSer}"
                        Click="btnVybratOblozhku_Click"/>
            </Grid>

            <!-- Текст книги -->
            <TextBlock Text="Текст книги" Foreground="#C4B5FD" Margin="0,0,0,4"/>
            <TextBox x:Name="txtContent"
                     Style="{StaticResource PolVvoda}"
                     Height="120" TextWrapping="Wrap" AcceptsReturn="True"
                     Margin="0,0,0,14"
                     VerticalScrollBarVisibility="Auto"/>

            <!-- Жанры -->
            <TextBlock Text="Жанры" Foreground="#C4B5FD" Margin="0,0,0,8"/>
            <WrapPanel x:Name="panelZhanry" Margin="0,0,0,20"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource BtnSer}"
                        Margin="0,0,12,0"
                        Click="btnOtmena_Click"/>
                <Button Content="Сохранить" Style="{StaticResource BtnFiolet}"
                        Click="btnSokhranit_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>